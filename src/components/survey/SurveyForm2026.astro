<script>
  const form = document.getElementById('validatedForm') as HTMLFormElement
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement

  // ========================================
  // 奨学生/非奨学生の判別（ビルド時に data 属性で埋め込み）
  // ========================================
  const isScholar = form.dataset.isScholar === 'true'

  // ========================================
  // URL パラメータからの自動入力（応募年度・メールアドレス）
  // ========================================
  const urlParams = new URLSearchParams(window.location.search)
  const yearParam = urlParams.get('year')
  const emailParam = urlParams.get('ref')

  if (yearParam) {
    const yearInput = document.getElementById('応募年度') as HTMLInputElement
    if (yearInput) yearInput.value = yearParam
  }
  if (emailParam) {
    const emailInput = document.getElementById('email') as HTMLInputElement
    if (emailInput) emailInput.value = emailParam
  }

  // ========================================
  // 文理自己認識「その他」自由記述の表示切替
  // ========================================
  const bunriSelfRadios = document.querySelectorAll(
    'input[name="応募時の文理自己認識"]',
  ) as NodeListOf<HTMLInputElement>
  const bunriSelfOtherWrapper = document.getElementById(
    'bunri-self-other-wrapper',
  ) as HTMLElement
  const bunriSelfOtherInput = bunriSelfOtherWrapper?.querySelector(
    'input',
  ) as HTMLInputElement

  bunriSelfRadios.forEach((radio) => {
    radio.addEventListener('change', () => {
      if (radio.value === 'その他' && radio.checked) {
        bunriSelfOtherWrapper.style.display = 'block'
      } else {
        bunriSelfOtherWrapper.style.display = 'none'
        if (bunriSelfOtherInput) bunriSelfOtherInput.value = ''
      }
    })
  })

  // ========================================
  // フォーム送信処理（formrun へネイティブ送信）
  // ========================================
  form.addEventListener('validated-submit', () => {
    // 連打防止: 送信ボタンを無効化 + テキスト変更
    submitBtn.disabled = true
    submitBtn.textContent = '送信中...'

    // hidden input で追加フィールドを注入
    const addHidden = (name: string, value: string) => {
      const input = document.createElement('input')
      input.type = 'hidden'
      input.name = name
      input.value = value
      form.appendChild(input)
    }

    addHidden('送信ID', crypto.randomUUID())
    addHidden('回答者種別', isScholar ? 'scholar' : 'non_scholar')

    // ネイティブ form 送信（formrun API が受信 → リダイレクト）
    form.submit()
  })
</script>
