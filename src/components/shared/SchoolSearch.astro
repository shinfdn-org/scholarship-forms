---
/**
 * SchoolSearch.astro - 学校名検索・自動補完コンポーネント
 *
 * school.json から学校データを読み込み、キーワード検索とフィルタリングによる学校名サジェストを提供
 *
 * 機能:
 * - キーワードによる学校名検索
 * - 学校種別（高校 / 中等 / 高専）によるフィルター
 * - 都道府県によるフィルター
 * - 検索結果のクリックで自動入力
 */

interface Props {
  /** 学校コード入力欄の name 属性 */
  codeName?: string
  /** 学校名入力欄の name 属性 */
  schoolName?: string
  /** 必須かどうか */
  required?: boolean
  /** データファイルのパス */
  dataPath?: string
}

import { prefectures } from '@data/prefectures'

const {
  codeName = 'school_code',
  schoolName = 'school_name',
  required = true,
  dataPath = `${import.meta.env.BASE_URL}data/school.json`,
} = Astro.props
---

<div class="school-search" data-path={dataPath}>
  <div class="form-group">
    <label>
      学校名を検索
      {required && <span class="required-badge">必須</span>}
    </label>

    <p class="description">
      下記の検索ボックスに学校名を入力して、学校名と学校コードを選択してください<br
      />
      自分の学校名が見つからない場合は、キーワードを短くして検索してください
    </p>

    <p class="description">
      ※ やまだ進太郎高校の場合、「やまだ」「進太郎」などで検索
      <br />※ 正式名称が漢字の場合は、漢字で入力してください（例：さくら×、桜◯）
      <br />※「◯◯県立」「高校」「高等学校」等を入れずに検索して下さい
    </p>

    <div class="form-inline-kensaku">
      <div>
        <input type="text" id="searchWord" name="学校キーワード検索" />
      </div>
      <button id="kensaku" type="button" class="btn-search">検索</button>
    </div>

    <ul
      id="suggestionList"
      class="suggestion-list"
      data-placeholder="検索結果がここに表示されます。"
    >
    </ul>

    <div class="form-group-school-code">
      <p class="description">
        さらに候補を絞りたい場合は、下記を選択してください。
      </p>
      <div class="form-inline-postal">
        <div>
          <select id="schoolTypeSelect" name="学校の種類">
            <option value="">（任意）学校の種類を選択</option>
            <option value="D1(高校)">高等学校（高校）</option>
            <option value="D2(中等)">中等教育学校（中高一貫校）</option>
            <option value="G1(高専)">高等専門学校（高専）</option>
          </select>
        </div>
        <div>
          <select id="prefSelect" name="都道府県">
            <option value="">（任意）都道府県を選択</option>
            {prefectures.map((pref) => <option value={pref}>{pref}</option>)}
          </select>
        </div>
      </div>
    </div>

    <div class="form-inline-school-name-code" style="margin-top: 1.5rem;">
      <div>
        <label>学校名</label>
        <input
          name={schoolName}
          id="schoolName"
          type="text"
          data-required={required}
          readonly
          placeholder="検索すると自動で入力されます"
        />
        <div class="error-text" data-formrun-show-if-error={schoolName}>
          入力してください
        </div>
      </div>
      <div>
        <label>学校コード</label>
        <input
          name={codeName}
          id="schoolCode"
          type="text"
          data-required={required}
          readonly
          placeholder="検索すると自動で入力されます"
        />
        <div class="error-text" data-formrun-show-if-error={codeName}>
          入力してください
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  interface School {
    name: string
    code: string
  }

  interface SchoolData {
    [schoolType: string]: {
      [prefecture: string]: School[]
    }
  }

  interface SearchResult extends School {
    type: string
    pref: string
  }

  /** 検索結果の最大表示件数 */
  const MAX_RESULTS = 20

  /** 表記揺れの同義語辞書（双方向でマッチ） */
  const SYNONYMS: [string, string][] = [
    ['高校', '高等学校'],
    ['中学', '中学校'],
    ['高専', '高等専門学校'],
    ['付属', '附属'],
  ]

  /** キーワードを同義語に展開する */
  function expandKeywords(keyword: string): string[] {
    const keywords = [keyword]
    for (const [a, b] of SYNONYMS) {
      if (keyword.includes(a)) {
        keywords.push(keyword.replace(a, b))
      }
      if (keyword.includes(b)) {
        keywords.push(keyword.replace(b, a))
      }
    }
    return [...new Set(keywords)]
  }

  /** リアルタイム検索のdebounce時間(ms) */
  const DEBOUNCE_MS = 200

  class SchoolSearchComponent {
    private container: HTMLElement
    private schoolData: SchoolData = {}
    private selectedPrefCode = ''
    private selectedSchoolType = ''
    private lastKeyword = ''
    private debounceTimer: number | null = null

    // DOM elements
    private suggestionList: HTMLUListElement
    private codeInput: HTMLInputElement
    private nameInput: HTMLInputElement
    private prefSelect: HTMLSelectElement
    private schoolTypeSelect: HTMLSelectElement
    private searchWord: HTMLInputElement
    private searchButton: HTMLButtonElement

    constructor(container: HTMLElement) {
      this.container = container

      this.suggestionList = container.querySelector(
        '#suggestionList',
      ) as HTMLUListElement
      this.codeInput = container.querySelector(
        '#schoolCode',
      ) as HTMLInputElement
      this.nameInput = container.querySelector(
        '#schoolName',
      ) as HTMLInputElement
      this.prefSelect = container.querySelector(
        '#prefSelect',
      ) as HTMLSelectElement
      this.schoolTypeSelect = container.querySelector(
        '#schoolTypeSelect',
      ) as HTMLSelectElement
      this.searchWord = container.querySelector(
        '#searchWord',
      ) as HTMLInputElement
      this.searchButton = container.querySelector(
        '#kensaku',
      ) as HTMLButtonElement

      this.init()
    }

    private async init() {
      const dataPath = this.container.dataset.path || '/data/school.json'

      // 初期プレースホルダー表示
      this.showPlaceholder()

      try {
        const response = await fetch(dataPath)
        this.schoolData = await response.json()
        this.setupEventListeners()
      } catch (error) {
        console.error('学校データの読み込みに失敗しました:', error)
        this.suggestionList.innerHTML = ''
        const li = document.createElement('li')
        li.className = 'suggestion-list-hint'
        li.textContent =
          '学校データの読み込みに失敗しました。ページを再読み込みしてください。'
        this.suggestionList.appendChild(li)
      }
    }

    private setupEventListeners() {
      // 検索ボタンクリック
      this.searchButton.addEventListener('click', () => this.onSearch())

      // リアルタイム検索（debounce付き）
      this.searchWord.addEventListener('input', () => {
        if (this.debounceTimer) {
          clearTimeout(this.debounceTimer)
        }
        this.debounceTimer = window.setTimeout(() => {
          this.onSearch()
        }, DEBOUNCE_MS)
      })

      // Enterキーで即時検索
      this.searchWord.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault()
          if (this.debounceTimer) {
            clearTimeout(this.debounceTimer)
          }
          this.onSearch()
        }
      })

      // フィルター変更時は既存の結果を再フィルタリング
      this.schoolTypeSelect.addEventListener('change', () => {
        this.selectedSchoolType = this.schoolTypeSelect.value
        if (this.lastKeyword) {
          this.showSuggestions(this.lastKeyword)
        }
      })

      this.prefSelect.addEventListener('change', () => {
        this.selectedPrefCode = this.prefSelect.value
        if (this.lastKeyword) {
          this.showSuggestions(this.lastKeyword)
        }
      })
    }

    /** 学校名を自由入力モードに切り替える */
    private enableManualInput() {
      this.codeInput.value = 'D999999999999'
      this.nameInput.value = ''
      this.nameInput.removeAttribute('readonly')
      this.nameInput.placeholder = '学校名を入力してください'
      this.nameInput.style.backgroundColor = '#fff'
      this.nameInput.focus()
    }

    private showPlaceholder() {
      const placeholder =
        this.suggestionList.dataset.placeholder ||
        '検索結果がここに表示されます。'
      this.suggestionList.innerHTML = ''
      const li = document.createElement('li')
      li.className = 'suggestion-list-placeholder'
      li.textContent = placeholder
      this.suggestionList.appendChild(li)
    }

    private onSearch() {
      const keyword = this.searchWord.value.trim()
      if (!keyword) {
        this.showPlaceholder()
        return
      }
      this.lastKeyword = keyword
      this.showSuggestions(keyword)
    }

    private showSuggestions(keyword: string) {
      const results: SearchResult[] = []
      const keywords = expandKeywords(keyword)

      for (const [schoolTypeKey, prefs] of Object.entries(this.schoolData)) {
        for (const [prefName, schools] of Object.entries(prefs)) {
          schools.forEach((school) => {
            // いずれかのキーワード（同義語含む）にマッチすればOK
            if (keywords.some((kw) => school.name.includes(kw))) {
              results.push({
                ...school,
                type: schoolTypeKey,
                pref: prefName,
              })
            }
          })
        }
      }

      const filteredResults = results.filter((school) => {
        const matchesType = this.selectedSchoolType
          ? school.type === this.selectedSchoolType
          : true
        const matchesPref = this.selectedPrefCode
          ? school.pref === this.selectedPrefCode
          : true
        return matchesType && matchesPref
      })

      this.suggestionList.innerHTML = ''

      if (filteredResults.length === 0) {
        const li = document.createElement('li')
        li.className = 'suggestion-list-hint'
        li.textContent = '該当する学校が見つかりませんでした'
        this.suggestionList.appendChild(li)
      } else {
        // 表示件数を制限
        const displayResults = filteredResults.slice(0, MAX_RESULTS)
        displayResults.forEach((school) => {
          const li = document.createElement('li')
          li.textContent = school.name
          li.addEventListener('click', () => {
            this.codeInput.value = school.code
            this.nameInput.value = school.name
            this.showPlaceholder()
          })
          this.suggestionList.appendChild(li)
        })

        // 結果が制限を超えた場合はヒントを表示
        if (filteredResults.length > MAX_RESULTS) {
          const li = document.createElement('li')
          li.className = 'suggestion-list-hint'
          li.textContent = `他 ${filteredResults.length - MAX_RESULTS} 件（絞り込んでください）`
          this.suggestionList.appendChild(li)
        }
      }

      // 常に「自分の学校が見つからない」オプションを追加
      const notFoundLi = document.createElement('li')
      notFoundLi.className = 'suggestion-list-not-found'
      notFoundLi.textContent = '自分の学校が見つからない場合はこちらをクリック'
      notFoundLi.addEventListener('click', () => {
        this.enableManualInput()
      })
      this.suggestionList.appendChild(notFoundLi)
    }
  }

  // Initialize all school search components
  document.querySelectorAll('.school-search').forEach((container) => {
    new SchoolSearchComponent(container as HTMLElement)
  })
</script>
